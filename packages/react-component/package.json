{
    "name": "@vessel-dsp/react-component",
    "version": "0.5.0",
    "description": "React components for Vessel DSP circuit and device editing surfaces.",
    "keywords": [
        "react",
        "schematic",
        "guitar-pedal",
        "electronics",
        "circuit"
    ],
    "homepage": "https://vessel-dsp.github.io/react-pedal-schematic/",
    "bugs": {
        "url": "https://github.com/vessel-dsp/react-pedal-schematic/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vessel-dsp/react-pedal-schematic.git"
    },
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "bun": "./src/index.tsx",
            "import": "./dist/index.js"
        },
        "./ui": {
            "types": "./dist/ui.d.ts",
            "bun": "./src/ui.tsx",
            "import": "./dist/ui.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src",
        "README.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dist-imports.ts dist",
        "clean": "rm -rf dist",
        "pack:dry-run": "npm pack --dry-run",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@vessel-dsp/core": "workspace:*"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
