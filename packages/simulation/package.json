{
    "name": "@vessel-dsp/simulation",
    "version": "0.5.0",
    "private": true,
    "description": "Simulation readiness, IR, and realtime adapter APIs for Vessel DSP circuit documents.",
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "bun": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./runtime": {
            "types": "./dist/runtime/index.d.ts",
            "bun": "./src/runtime/index.ts",
            "import": "./dist/runtime/index.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src",
        "README.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dist-imports.ts dist",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@vessel-dsp/core": "workspace:*"
    }
}
