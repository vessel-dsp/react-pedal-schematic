    <Component _Type="Circuit.Label, Circuit, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" Text="CD4013 sub-octave" Subtext="Comparator → 4013 toggle FF → blend with dry. Per Rocktave / U-Boat reference designs." Name="_title" />
  </Element>
