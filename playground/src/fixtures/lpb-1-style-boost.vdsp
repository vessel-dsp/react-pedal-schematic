        value: 1e-12
        unit: ""
      BF:
        raw: "120"
        value: 120
        unit: ""
      BR:
        raw: "2"
        value: 2
        unit: ""
      n:
        raw: "1"
        value: 1
        unit: ""
      Name: Q1
      PartNumber: "2N5088"
      Description: "Compact NPN BJT approximation."
