          y: 120
    properties:
      Capacitance:
        raw: "100 nF"
        value: 1.0000000000000001e-7
        unit: F
      Material: film
      Name: CIN
      Description: "Input coupling capacitor."
  - id: RB1
    kind: resistor
    name: RB1
    sourceTypeName: "Circuit.Resistor, Circuit, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null"
    origin:
