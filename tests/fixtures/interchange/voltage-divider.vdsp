schema: circuit-interchange/v2
metadata:
  name: Voltage Divider
  description: Simple resistive voltage divider in .vdsp interchange format.
  partNumber: ""
source:
  format: interchange
  filename: voltage-divider.vdsp
components:
  - id: R1
    kind: resistor
    name: R1
    origin:
      x: 0
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: a
        node: 1
        position:
          x: 0
          y: -10
      - name: b
        node: 2
        position:
          x: 0
          y: 10
    properties:
      Resistance:
        raw: "10k"
        value: 10000
        unit: ""
  - id: R2
    kind: resistor
    name: R2
    origin:
      x: 0
      y: 30
    rotation: 0
    flipped: false
    terminals:
      - name: a
        node: 2
        position:
          x: 0
          y: 20
      - name: b
        node: 0
        position:
          x: 0
          y: 40
    properties:
      Resistance:
        raw: "10k"
        value: 10000
        unit: ""
  - id: GND1
    kind: ground
    name: GND1
    origin:
      x: 0
      y: 50
    rotation: 0
    flipped: false
    terminals:
      - name: t
        node: 0
        position:
          x: 0
          y: 50
    properties: {}
nodes:
  - id: 0
    name: GND
    isGround: true
    members:
      - componentId: R2
        terminalName: b
      - componentId: GND1
        terminalName: t
  - id: 1
    name: VIN
    isGround: false
    members:
      - componentId: R1
        terminalName: a
  - id: 2
    name: VOUT
    isGround: false
    members:
      - componentId: R1
        terminalName: b
      - componentId: R2
        terminalName: a
wires: []
directives: []
diagnostics: []
rawAttributes:
  format: interchange
