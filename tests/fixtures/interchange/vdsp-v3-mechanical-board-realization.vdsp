      - name: "1"
        position:
          x: 70
          y: 10
      - name: "2"
        position:
          x: 80
          y: 10
      - name: "3"
        position:
          x: 90
          y: 10
    properties:
      Resistance:
        raw: 500k
        value: 500000
        unit: Ω
      Taper: reverse-log
    sourceTypeName: null
  - id: LEVEL
    kind: potentiometer
    name: LEVEL
    origin:
      x: 120
      y: 0
    rotation: 0
    flipped: false
