          role: lead
          terminalName: anode
          holeOffset:
            row: 0
            column: 0
        - id: cathode
          role: lead
          terminalName: cathode
          holeOffset:
            row: 1
            column: 0
    - id: jack-ts-board-edge
      boardApplicability:
        family: prototype-board
        kind: stripboard
