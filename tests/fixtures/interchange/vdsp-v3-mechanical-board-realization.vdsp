          role: lug
          terminalName: sleeve
          holeOffset:
            row: 1
            column: 0

deviceInterface:
  controls:
    - id: DRIVE
      label: DRIVE
      kind: knob
      role: gain
      groupId: top-panel
      order: 1
      binding:
        componentId: DRIVE
    - id: LEVEL
      label: LEVEL
      kind: knob
      role: level
      groupId: top-panel
      order: 2
      binding:
        componentId: LEVEL
    - id: TONE_MODE
      label: TONE
      kind: selector
      role: tone-mode
      groupId: top-panel
      order: 3
      binding:
        componentId: TONE
    - id: BYPASS
      label: BYPASS
      kind: footswitch
      role: bypass
      groupId: top-panel
      order: 4
      binding:
        componentId: SW_BYPASS
    - id: STATUS_LED
      label: ON
      kind: led
      role: status
      groupId: top-panel
      order: 5
      binding:
        componentId: LED_STATUS
    - id: INPUT_JACK
      label: INPUT
      kind: jack
      role: audio-input
      groupId: io-panel
      order: 6
      binding:
        componentId: J_IN
    - id: OUTPUT_JACK
      label: OUTPUT
      kind: jack
      role: audio-output
      groupId: io-panel
      order: 7
      binding:
        componentId: J_OUT
    - id: POWER_JACK
      label: DC 9V
      kind: jack
      role: power-input
      groupId: io-panel
      order: 8
      binding:
        componentId: J_DC

panel:
  faces:
    - id: top
      label: Top
      layout:
        kind: stompbox-grid
        rows: 4
        columns: 2
        indexing: one-based
        rowOrder: top-to-bottom
        columnOrder: left-to-right
      geometry:
        units: mm
        surface: top
        usableRectMm:
          x: 6
          y: 8
          width: 48
          height: 96
      elements:
        - id: panel-drive
          bind:
            componentId: DRIVE
          kind: knob
          label: DRIVE
          interfaceControlId: DRIVE
          grid:
            row: 1
            column: 1
          physical:
            units: mm
            centerMm:
              x: 20
              y: 28
            drillDiameterMm: 7
            partProfileId: pot-alpha-16
            locked: true
        - id: panel-level
          bind:
            componentId: LEVEL
          kind: knob
          label: LEVEL
          interfaceControlId: LEVEL
          grid:
            row: 1
            column: 2
          physical:
            units: mm
            centerMm:
              x: 40
              y: 28
            drillDiameterMm: 7
            partProfileId: pot-alpha-16
            locked: true
        - id: panel-tone-mode
          bind:
            componentId: TONE
          kind: selector
          label: TONE
          interfaceControlId: TONE_MODE
          grid:
            row: 2
            column: 1
          physical:
            units: mm
            centerMm:
              x: 20
              y: 50
            drillDiameterMm: 6.5
            partProfileId: toggle-spdt-mini
            locked: true
        - id: panel-status-led
          bind:
            componentId: LED_STATUS
          kind: led
          label: ON
          interfaceControlId: STATUS_LED
          grid:
            row: 2
            column: 2
          physical:
            units: mm
            centerMm:
              x: 40
              y: 50
            drillDiameterMm: 5
            partProfileId: led-5mm-panel
            locked: true
        - id: panel-bypass
          bind:
            componentId: SW_BYPASS
          kind: footswitch
          label: BYPASS
          interfaceControlId: BYPASS
          grid:
            row: 4
            column: 1
            columnSpan: 2
          physical:
            units: mm
            centerMm:
              x: 30
              y: 88
            drillDiameterMm: 12
            partProfileId: footswitch-3pdt
            locked: true
    - id: left-side
      label: Left Side
      layout:
        kind: stompbox-grid
        rows: 1
        columns: 1
        indexing: one-based
      geometry:
        units: mm
        surface: left-side
        usableRectMm:
          x: 0
          y: 16
          width: 31
          height: 18
      elements:
        - id: panel-input-jack
          bind:
            componentId: J_IN
          kind: jack
          label: INPUT
          interfaceControlId: INPUT_JACK
          grid:
            row: 1
            column: 1
          physical:
            units: mm
            centerMm:
              x: 15.5
              y: 25
            drillDiameterMm: 9.5
            partProfileId: jack-mono-ts-enclosed
            locked: true
    - id: right-side
      label: Right Side
      layout:
        kind: stompbox-grid
        rows: 1
        columns: 1
        indexing: one-based
      geometry:
        units: mm
        surface: right-side
        usableRectMm:
          x: 0
          y: 16
          width: 31
          height: 18
      elements:
        - id: panel-output-jack
          bind:
            componentId: J_OUT
          kind: jack
          label: OUTPUT
          interfaceControlId: OUTPUT_JACK
          grid:
            row: 1
            column: 1
          physical:
            units: mm
            centerMm:
              x: 15.5
              y: 25
            drillDiameterMm: 9.5
            partProfileId: jack-mono-ts-enclosed
            locked: true
    - id: top-edge
      label: Top Edge
      layout:
        kind: stompbox-grid
        rows: 1
        columns: 1
        indexing: one-based
      geometry:
        units: mm
        surface: top-edge
        usableRectMm:
          x: 0
          y: 16
          width: 31
          height: 18
      elements:
        - id: panel-dc-jack
          bind:
            componentId: J_DC
          kind: jack
          label: DC 9V
          interfaceControlId: POWER_JACK
          grid:
            row: 1
            column: 1
          physical:
            units: mm
            centerMm:
              x: 15.5
              y: 25
            drillDiameterMm: 8
            partProfileId: dc-jack-2.1mm-panel
            locked: true

offBoardWiring:
  schema: offboard-wiring/v1
  source: reviewed
  coverage: selected-build-complete
  harnesses:
    - id: panel-to-board
      status: complete
      notes: Complete selected-build harness; every selected panel terminal has a board endpoint or chassis-ground endpoint.
      endpoints:
        - id: drive-lug-1
          kind: panel-component-terminal
          componentId: DRIVE
          terminalName: "1"
          panelElementId: panel-drive
        - id: drive-edge-1
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_DRIVE_1
        - id: drive-lug-2
          kind: panel-component-terminal
          componentId: DRIVE
          terminalName: "2"
          panelElementId: panel-drive
        - id: drive-edge-2
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_DRIVE_2
        - id: drive-lug-3
          kind: panel-component-terminal
          componentId: DRIVE
          terminalName: "3"
          panelElementId: panel-drive
        - id: drive-edge-3
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_DRIVE_3
        - id: level-lug-1
          kind: panel-component-terminal
          componentId: LEVEL
          terminalName: "1"
          panelElementId: panel-level
        - id: level-edge-1
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_LEVEL_1
        - id: level-lug-2
          kind: panel-component-terminal
          componentId: LEVEL
          terminalName: "2"
          panelElementId: panel-level
        - id: level-edge-2
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_LEVEL_2
        - id: level-lug-3
          kind: panel-component-terminal
          componentId: LEVEL
          terminalName: "3"
          panelElementId: panel-level
        - id: level-edge-3
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_LEVEL_3
        - id: tone-common
          kind: panel-component-terminal
          componentId: TONE
          terminalName: common
          panelElementId: panel-tone-mode
        - id: tone-edge-common
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_TONE_COMMON
        - id: tone-throw-a
          kind: panel-component-terminal
          componentId: TONE
          terminalName: throw_a
          panelElementId: panel-tone-mode
        - id: tone-edge-throw-a
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_TONE_THROW_A
        - id: tone-throw-b
          kind: panel-component-terminal
          componentId: TONE
          terminalName: throw_b
          panelElementId: panel-tone-mode
        - id: tone-edge-throw-b
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_TONE_THROW_B
        - id: status-led-anode
          kind: panel-component-terminal
          componentId: LED_STATUS
          terminalName: anode
          panelElementId: panel-status-led
        - id: status-led-board
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_LED_ANODE
        - id: status-led-cathode
          kind: panel-component-terminal
          componentId: LED_STATUS
          terminalName: cathode
          panelElementId: panel-status-led
        - id: status-led-cathode-board
          kind: board-terminal
          boardId: main-vero
          terminalId: EDGE_LED_CATHODE
        - id: bypass-common
          kind: footswitch-terminal
          componentId: SW_BYPASS
          terminalName: p1_common
          panelElementId: panel-bypass
