components:
  - id: R1
    kind: resistor
    name: R1
    origin:
      x: 0
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: a
        position:
          x: 0
          y: 0
      - name: b
        position:
          x: 20
          y: 0
    properties:
      Resistance:
        raw: 10k
        value: 10000
        unit: Ω
    sourceTypeName: null
  - id: C1
    kind: capacitor
    name: C1
    origin:
      x: 40
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: a
        position:
          x: 20
          y: 0
      - name: b
        position:
          x: 40
          y: 0
    properties:
      Capacitance:
        raw: 100n
        value: 0.0000001
        unit: F
    sourceTypeName: null
  - id: DRIVE
    kind: potentiometer
    name: DRIVE
    origin:
      x: 80
      y: 0
    rotation: 0
    flipped: false
