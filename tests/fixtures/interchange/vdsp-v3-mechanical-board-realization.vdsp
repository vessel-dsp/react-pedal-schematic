schema: circuit-interchange/v3

metadata:
  name: VDSP V3 Mechanical Board Realization Sample
  description: Review sample covering mechanical, build scope, BOM, profile, footprint, panel, off-board wiring, and board realization fields.
  partNumber: SAMPLE-V3-MECHANICAL-BOARD

source:
  format: interchange
  filename: vdsp-v3-mechanical-board-realization.sample.vdsp

device:
  id: sample-drive
  version: 3
  kind: audio-pedal
  family: distortion
  model: sample-drive-v3
  audioProcessing: true

controlGroups:
  - id: top-panel
    name: Top Panel
    role: primary-controls
  - id: io-panel
    name: Audio And Power
    role: io-controls

controlContexts:
  - id: normal-operation
    name: Normal Operation
    role: default

mechanical:
  schema: device-mechanical/v1
  units: mm
  coordinateSystem:
    origin: top-left
    xAxis: right
    yAxis: down
  enclosure:
    profileId: enclosure-1590b
    label: Hammond 1590B
    outerSizeMm:
      width: 60
      height: 112
      depth: 31
    wallThicknessMm: 1.5
  internalBoard:
    preferredBoardId: main-vero
    usableRectMm:
      x: 7
      y: 16
      width: 46
      height: 72
    keepoutRectsMm:
      - id: footswitch-body
        x: 18
        y: 82
        width: 24
        height: 22

build:
  schema: build-scope/v1
  intent: diy-build-artifact
  completeness: complete-selected-build
  selectedBoardId: main-vero
  selectedOffBoardWiringHarnessIds:
    - panel-to-board
  alternateBoardIds:
    - perfboard-alt
    - breadboard-pattern-proto
    - fabricated-pcb
  bomScope: selected-board-plus-shared-build-items

bom:
  schema: build-bom/v1
  items:
    - id: bom-r1
      refs:
        - kind: component
          componentId: R1
      quantity: 1
      value: 10k
      partProfileId: resistor-axial-7.5mm
      category: resistor
      sku: RES-10K-AXIAL
    - id: bom-c1
      refs:
        - kind: component
          componentId: C1
      quantity: 1
      value: 100n
      partProfileId: capacitor-box-5mm
      category: capacitor
      sku: CAP-100N-BOX
    - id: bom-drive
      refs:
        - kind: component
          componentId: DRIVE
        - kind: device-interface-control
          controlId: DRIVE
        - kind: panel-element
          panelElementId: panel-drive
      quantity: 1
      value: 500k reverse-log
      partProfileId: pot-alpha-16
      category: potentiometer
      sku: POT-16-500KC
    - id: bom-level
      refs:
        - kind: component
          componentId: LEVEL
        - kind: device-interface-control
          controlId: LEVEL
        - kind: panel-element
          panelElementId: panel-level
      quantity: 1
      value: 10k log
      partProfileId: pot-alpha-16
      category: potentiometer
      sku: POT-16-10KA
    - id: bom-tone-selector
      refs:
        - kind: component
          componentId: TONE
        - kind: device-interface-control
          controlId: TONE_MODE
        - kind: panel-element
          panelElementId: panel-tone-mode
      quantity: 1
      value: 2-position tone selector
      partProfileId: toggle-spdt-mini
      category: switch
      sku: SWT-SPDT-MINI
    - id: bom-footswitch
      refs:
        - kind: component
          componentId: SW_BYPASS
        - kind: device-interface-control
          controlId: BYPASS
        - kind: panel-element
          panelElementId: panel-bypass
      quantity: 1
      value: 3PDT latching footswitch
      partProfileId: footswitch-3pdt
      category: switch
      sku: FSW-3PDT
    - id: bom-status-led
      refs:
        - kind: component
          componentId: LED_STATUS
        - kind: device-interface-control
          controlId: STATUS_LED
        - kind: panel-element
          panelElementId: panel-status-led
      quantity: 1
      value: red 5mm LED
      partProfileId: led-5mm-panel
      category: led
      sku: LED-5MM-RED
    - id: bom-input-jack
      refs:
        - kind: component
          componentId: J_IN
        - kind: device-interface-control
          controlId: INPUT_JACK
        - kind: panel-element
          panelElementId: panel-input-jack
      quantity: 1
      value: mono TS input jack
      partProfileId: jack-mono-ts-enclosed
      category: jack
      sku: JACK-TS-MONO
    - id: bom-output-jack
      refs:
        - kind: component
          componentId: J_OUT
        - kind: device-interface-control
          controlId: OUTPUT_JACK
        - kind: panel-element
          panelElementId: panel-output-jack
      quantity: 1
      value: mono TS output jack
      partProfileId: jack-mono-ts-enclosed
      category: jack
      sku: JACK-TS-MONO
    - id: bom-dc-jack
      refs:
        - kind: component
          componentId: J_DC
        - kind: device-interface-control
          controlId: POWER_JACK
        - kind: panel-element
          panelElementId: panel-dc-jack
      quantity: 1
      value: 2.1mm DC power jack
      partProfileId: dc-jack-2.1mm-panel
      category: power-jack
      sku: JACK-DC-2.1MM
    - id: bom-main-vero
      refs:
        - kind: board
          boardId: main-vero
      quantity: 1
      value: 18 x 24 stripboard
      category: prototype-board
      sku: VERO-18X24
    - id: bom-enclosure
      refs:
        - kind: freeform-build-item
          label: Hammond 1590B enclosure
      quantity: 1
      value: Hammond 1590B
      partProfileId: enclosure-1590b
      category: enclosure
      sku: ENC-1590B
    - id: bom-hookup-wire
      refs:
        - kind: freeform-build-item
          label: 24 AWG stranded hookup wire
      quantity: 1
      value: 1 meter mixed colors
      category: wire
      sku: WIRE-24AWG-MIX

partProfiles:
  schema: part-profile-catalog/v1
  resolution: embedded
  units: mm
  profiles:
    - id: resistor-axial-7.5mm
      kind: resistor
      body:
        lengthMm: 6.5
        diameterMm: 2.4
      leads:
        pitchMm: 7.5
        drillDiameterMm: 0.9
      compatibleFootprintIds:
        - axial-resistor-7.5mm-through-hole
        - axial-resistor-7.5mm-perfboard
        - axial-resistor-7.5mm-pcb
      clearance:
        bodyKeepoutMm: 1
    - id: capacitor-box-5mm
      kind: capacitor
      body:
        widthMm: 7.2
        heightMm: 6
        depthMm: 3
      leads:
        pitchMm: 5
        drillDiameterMm: 0.8
      compatibleFootprintIds:
        - capacitor-box-5mm-through-hole
        - capacitor-box-5mm-pcb
      clearance:
        bodyKeepoutMm: 1
    - id: pot-alpha-16
      kind: potentiometer
      panel:
        drillDiameterMm: 7
        keepoutDiameterMm: 17
        shaftDiameterMm: 6
      lugs:
        count: 3
        pitchMm: 2.54
      compatibleFootprintIds:
        - pot-alpha-16-board-lugs
      clearance:
        bodyDepthMm: 12
        bodyKeepoutMm: 1.5
    - id: toggle-spdt-mini
      kind: selector
      panel:
        drillDiameterMm: 6.5
        keepoutDiameterMm: 12
        leverSlotMm:
          width: 4
          height: 8
      lugs:
        count: 3
        pitchMm: 2.54
      compatibleFootprintIds:
        - switch-spdt-board-lugs
      clearance:
        bodyDepthMm: 10
        bodyKeepoutMm: 1.5
    - id: footswitch-3pdt
      kind: footswitch
      panel:
        drillDiameterMm: 12
        keepoutDiameterMm: 22
      lugs:
        count: 9
        layout: 3x3
      compatibleFootprintIds:
        - footswitch-3pdt-lugs
      clearance:
        bodyDepthMm: 28
        bodyKeepoutMm: 2
    - id: led-5mm-panel
      kind: led
      panel:
        drillDiameterMm: 5
        keepoutDiameterMm: 8
      leads:
        count: 2
        pitchMm: 2.54
      compatibleFootprintIds:
        - led-5mm-through-hole
      clearance:
        bodyDepthMm: 7
        bodyKeepoutMm: 1
    - id: jack-mono-ts-enclosed
      kind: jack
      panel:
        drillDiameterMm: 9.5
        keepoutDiameterMm: 16
      lugs:
        count: 2
        pitchMm: 5
      compatibleFootprintIds:
        - jack-ts-board-edge
      clearance:
        bodyDepthMm: 25
        bodyKeepoutMm: 2
    - id: dc-jack-2.1mm-panel
      kind: power-jack
      panel:
        drillDiameterMm: 8
        keepoutDiameterMm: 15
      lugs:
        count: 2
        pitchMm: 5
      compatibleFootprintIds:
        - jack-dc-board-edge
      clearance:
        bodyDepthMm: 21
        bodyKeepoutMm: 2
    - id: enclosure-1590b
      kind: enclosure
      enclosure:
        outerSizeMm:
          width: 60
          height: 112
          depth: 31
        wallThicknessMm: 1.5
      clearance:
        lidLipKeepoutMm: 3

footprints:
  schema: board-footprint-catalog/v1
  resolution: embedded
  units: mm
  footprints:
    - id: axial-resistor-7.5mm-through-hole
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
        - id: "1"
          role: lead
          terminalName: a
          holeOffset:
            row: 0
            column: 0
        - id: "2"
          role: lead
          terminalName: b
          holeOffset:
            row: 1
            column: 3
      courtyard:
        widthMm: 9
        heightMm: 3
    - id: axial-resistor-7.5mm-perfboard
      boardApplicability:
        family: prototype-board
        kind: perfboard
        subtype: isolated-pad
      pads:
        - id: "1"
          role: lead
          terminalName: a
          holeOffset:
            row: 0
            column: 0
        - id: "2"
          role: lead
          terminalName: b
          holeOffset:
            row: 0
            column: 3
    - id: axial-resistor-7.5mm-pcb
      boardApplicability:
        family: fabricated-board
        kind: pcb
        subtype: single-sided-through-hole
      pads:
        - id: "1"
          role: lead
          terminalName: a
          positionMm:
            x: 0
            y: 0
          drillDiameterMm: 0.9
          copperDiameterMm: 1.8
        - id: "2"
          role: lead
          terminalName: b
          positionMm:
            x: 7.5
            y: 0
          drillDiameterMm: 0.9
          copperDiameterMm: 1.8
    - id: capacitor-box-5mm-through-hole
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
        - id: "1"
          role: lead
          terminalName: a
          holeOffset:
            row: 0
            column: 0
        - id: "2"
          role: lead
          terminalName: b
          holeOffset:
            row: 1
            column: 2
    - id: capacitor-box-5mm-pcb
      boardApplicability:
        family: fabricated-board
        kind: pcb
        subtype: single-sided-through-hole
      pads:
        - id: "1"
          role: lead
          terminalName: a
          positionMm:
            x: 0
            y: 0
          drillDiameterMm: 0.8
          copperDiameterMm: 1.6
        - id: "2"
          role: lead
          terminalName: b
          positionMm:
            x: 5
            y: 0
          drillDiameterMm: 0.8
          copperDiameterMm: 1.6
    - id: pot-alpha-16-board-lugs
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
        - id: lug-1
          role: lug
          terminalName: "1"
          holeOffset:
            row: 0
            column: 0
        - id: lug-2
          role: lug
          terminalName: "2"
          holeOffset:
            row: 1
            column: 0
        - id: lug-3
          role: lug
          terminalName: "3"
          holeOffset:
            row: 2
            column: 0
    - id: switch-spdt-board-lugs
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
        - id: common
          role: lug
          terminalName: common
          holeOffset:
            row: 0
            column: 0
        - id: throw-a
          role: lug
          terminalName: throw_a
          holeOffset:
            row: 1
            column: 0
        - id: throw-b
          role: lug
          terminalName: throw_b
          holeOffset:
            row: 2
            column: 0
    - id: footswitch-3pdt-lugs
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
        - id: p1-common
          role: lug
          terminalName: p1_common
          holeOffset:
            row: 0
            column: 0
        - id: p1-throw-a
          role: lug
          terminalName: p1_throw_a
          holeOffset:
            row: 1
            column: 0
        - id: p1-throw-b
          role: lug
          terminalName: p1_throw_b
          holeOffset:
            row: 2
            column: 0
        - id: p2-common
          role: lug
          terminalName: p2_common
          holeOffset:
            row: 3
            column: 0
        - id: p2-throw-a
          role: lug
          terminalName: p2_throw_a
          holeOffset:
            row: 4
            column: 0
        - id: p2-throw-b
          role: lug
          terminalName: p2_throw_b
          holeOffset:
            row: 5
            column: 0
        - id: p3-common
          role: lug
          terminalName: p3_common
          holeOffset:
            row: 6
            column: 0
        - id: p3-throw-a
          role: lug
          terminalName: p3_throw_a
          holeOffset:
            row: 7
            column: 0
        - id: p3-throw-b
          role: lug
          terminalName: p3_throw_b
          holeOffset:
            row: 8
            column: 0
    - id: led-5mm-through-hole
      boardApplicability:
        family: prototype-board
        kind: stripboard
        subtype: veroboard
      pads:
