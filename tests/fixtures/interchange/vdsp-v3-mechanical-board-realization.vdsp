      - name: "1"
        position:
          x: 110
          y: 10
      - name: "2"
        position:
          x: 120
          y: 10
      - name: "3"
        position:
          x: 130
          y: 10
    properties:
      Resistance:
        raw: 10k
        value: 10000
        unit: Ω
      Taper: log
    sourceTypeName: null
  - id: TONE
    kind: switch
    name: TONE
    origin:
      x: 160
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: common
        position:
          x: 160
          y: 0
      - name: throw_a
        position:
          x: 150
          y: -10
      - name: throw_b
        position:
          x: 170
          y: -10
    properties:
      Positions: 2
    sourceTypeName: Circuit.SPDT
  - id: SW_BYPASS
    kind: switch
    name: SW_BYPASS
    origin:
      x: 200
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: p1_common
        position:
          x: 190
          y: 0
      - name: p1_throw_a
        position:
          x: 190
          y: -10
      - name: p1_throw_b
        position:
          x: 190
          y: 10
      - name: p2_common
        position:
          x: 200
          y: 0
      - name: p2_throw_a
        position:
          x: 200
          y: -10
      - name: p2_throw_b
        position:
          x: 200
          y: 10
      - name: p3_common
        position:
          x: 210
          y: 0
      - name: p3_throw_a
        position:
          x: 210
          y: -10
      - name: p3_throw_b
        position:
          x: 210
          y: 10
    properties:
      PartNumber: 3PDT footswitch
    sourceTypeName: Circuit.3PDT
  - id: LED_STATUS
    kind: led
    name: LED_STATUS
    origin:
      x: 240
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: anode
        position:
          x: 240
          y: -10
      - name: cathode
        position:
          x: 240
          y: 10
    properties:
      Color: red
      Model: LED_RED
    sourceTypeName: Circuit.LED
  - id: J_IN
    kind: jack
    name: J_IN
    origin:
      x: 280
      y: 0
    rotation: 0
    flipped: false
    terminals:
      - name: tip
        position:
          x: 280
          y: -10
      - name: sleeve
        position:
          x: 280
          y: 10
    properties:
