        terminalRef:
          componentId: LEVEL
          terminalName: "2"
        hole:
          row: 8
          column: 13
      - id: EDGE_INPUT_SLEEVE
        role: offboard-connection
        terminalRef:
          componentId: J_IN
          terminalName: sleeve
        hole:
          row: 8
          column: 14
      - id: EDGE_OUTPUT_SLEEVE
        role: offboard-connection
        terminalRef:
          componentId: J_OUT
          terminalName: sleeve
        hole:
          row: 8
          column: 15
      - id: EDGE_DC_SLEEVE
        role: power-ground
        terminalRef:
          componentId: J_DC
          terminalName: sleeve
        hole:
          row: 8
          column: 16
      - id: EDGE_DRIVE_2
        role: offboard-connection
        terminalRef:
          componentId: DRIVE
          terminalName: "2"
        hole:
          row: 9
          column: 17
      - id: EDGE_DRIVE_3
        role: offboard-connection
        terminalRef:
          componentId: DRIVE
          terminalName: "3"
        hole:
          row: 10
          column: 17
      - id: EDGE_LEVEL_1
        role: offboard-connection
        terminalRef:
          componentId: LEVEL
          terminalName: "1"
        hole:
          row: 11
          column: 17
      - id: EDGE_LEVEL_3
        role: offboard-connection
        terminalRef:
          componentId: LEVEL
          terminalName: "3"
        hole:
          row: 12
          column: 17
      - id: EDGE_OUTPUT_TIP
        role: offboard-connection
        terminalRef:
          componentId: J_OUT
          terminalName: tip
        hole:
          row: 12
          column: 16
      - id: EDGE_TONE_COMMON
        role: offboard-connection
