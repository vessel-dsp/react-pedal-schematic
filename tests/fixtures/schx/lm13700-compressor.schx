<?xml version="1.0" encoding="utf-8"?>
<Schematic Name="LM13700 OTA compressor (Dyna Comp-style)" Description="Ross / Dyna Comp topology with the LM13700 OTA at the heart: 2N3904 emitter-follower input, OTA gain stage with Iabc driven by the envelope detector (rectifier + integrator), SUSTAIN pot sets compression amount, LEVEL pot sets output volume. References: cushychicken.github.io Dyna Comp LTspice analysis, valvewizard.co.uk Engineer's Thumb, ElectroSmash Dyna Comp analysis." PartNumber="">
