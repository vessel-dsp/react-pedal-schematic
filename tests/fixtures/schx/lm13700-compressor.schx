    <Component _Type="Circuit.Label, Circuit, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" Text="LM13700 OTA compressor" Subtext="Emitter-follower → LM13700 OTA → rectifier envelope detector → Iabc feedback. SUSTAIN + LEVEL pots." Name="_title" />
  </Element>
