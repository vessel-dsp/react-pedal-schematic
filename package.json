{
    "name": "circuit-preview-editor",
    "version": "0.0.0",
    "description": "Web circuit editor library for audio electronics — .schx and SPICE netlist import/export, preview, and light editing.",
    "type": "module",
    "private": true,
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./ui": {
            "types": "./dist/ui/index.d.ts",
            "import": "./dist/ui/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "preview": "vite preview",
        "build:playground": "vite build",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf dist gh-pages",
        "generate:symbols": "bun run scripts/generate-symbol-content.ts",
        "generate:canvas-bg": "bun run scripts/generate-canvas-bg.ts"
    },
    "devDependencies": {
        "@joint/core": "4.2.4",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "latest",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^6.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "radix-ui": "^1.4.3",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.6.0",
        "vite": "^8.0.16"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    }
}
