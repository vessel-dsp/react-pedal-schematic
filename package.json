{
    "name": "@vessel-dsp/workspace",
    "version": "0.5.0",
    "private": true,
    "description": "Workspace for Vessel DSP circuit, device, React, and simulation packages.",
    "license": "MIT",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "bun run --cwd packages/core build && bun run --cwd packages/react-component build && bun run --cwd packages/simulation build && bun run check:dist",
        "build:playground": "vite build",
        "check:dist": "node scripts/check-dist-entrypoints.mjs",
        "clean": "rm -rf packages/*/dist gh-pages",
        "clean:dist": "rm -rf packages/*/dist",
        "dev": "vite",
        "generate:canvas-bg": "bun run scripts/generate-canvas-bg.ts",
        "generate:symbols": "bun run scripts/generate-symbol-content.ts",
        "lint": "biome lint --diagnostic-level=error .",
        "pack:dry-run": "bun run --cwd packages/core pack:dry-run && bun run --cwd packages/react-component pack:dry-run",
        "prepack": "bun run clean:dist && bun run typecheck && bun test && bun run build",
        "preview": "vite preview",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@joint/core": "4.2.4",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "latest",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^6.0.2",
        "circuit-json": "0.0.433",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "radix-ui": "^1.4.3",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.6.0",
        "vite": "^8.0.16",
        "zod": "3"
    },
    "packageManager": "bun@1.2.2"
}
