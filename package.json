{
    "name": "@vessel-dsp/react-pedal-schematic",
    "version": "0.2.5",
    "description": "React schematic editor library for guitar pedal circuits with LiveSPICE, LTspice, and SPICE import helpers.",
    "keywords": [
        "react",
        "schematic",
        "guitar-pedal",
        "electronics",
        "spice",
        "ltspice",
        "livespice"
    ],
    "homepage": "https://vessel-dsp.github.io/react-pedal-schematic/",
    "bugs": {
        "url": "https://github.com/vessel-dsp/react-pedal-schematic/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vessel-dsp/react-pedal-schematic.git"
    },
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/ui/index.d.ts",
            "import": "./dist/ui/index.js"
        },
        "./core": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./ui": {
            "types": "./dist/ui/index.d.ts",
            "import": "./dist/ui/index.js"
        },
        "./package.json": {
            "default": "./package.json"
        }
    },
    "main": "./dist/ui/index.js",
    "module": "./dist/ui/index.js",
    "types": "./dist/ui/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE.md",
        "DOCUMENT.md",
        "CHANGELOG.md",
        "docs/images",
        "examples"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && bun run scripts/fix-dist-imports.ts && bun run check:dist",
        "build:playground": "vite build",
        "check:dist": "node scripts/check-dist-entrypoints.mjs",
        "clean": "rm -rf dist gh-pages",
        "clean:dist": "rm -rf dist",
        "dev": "vite",
        "generate:canvas-bg": "bun run scripts/generate-canvas-bg.ts",
        "generate:symbols": "bun run scripts/generate-symbol-content.ts",
        "prepack": "bun run clean:dist && bun run typecheck && bun test && bun run build",
        "pack:dry-run": "npm pack --dry-run",
        "preview": "vite preview",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@joint/core": "4.2.4",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "latest",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^6.0.2",
        "circuit-json": "0.0.433",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "radix-ui": "^1.4.3",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.6.0",
        "vite": "^8.0.16",
        "zod": "3"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "bun@1.2.2"
}
